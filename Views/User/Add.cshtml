@model User

@{
    ViewData["Title"] = "Add User";
}

<section class="management-page position-relative overflow-hidden">

    <div class="blur-circle bg-primary-gradient position-absolute top-0 start-0 translate-middle"></div>

    <div class="container position-relative z-index-2">

        <div class="management-hero d-flex justify-content-between align-items-end">

            <div>
                <span class="management-eyebrow">
                    User Management
                </span>

                <h1 class="management-title">
                    Add New User
                </h1>

                <p class="management-subtitle">
                    Create a new user account for the platform.
                </p>
            </div>

            <a asp-action="Index" class="btn btn-outline-primary rounded-custom px-4 py-2 fw-semibold">
                Back
            </a>

        </div>


        <div class="management-card p-4">

            <form asp-action="Add" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-4">
                </div>

                <div class="row g-4">

                    <div class="col-md-6">

                        <label asp-for="FullName" class="form-label fw-semibold">
                        </label>

                        <input asp-for="FullName" class="form-control rounded-custom" />

                        <span asp-validation-for="FullName" class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="Email" class="form-label fw-semibold">
                        </label>

                        <input asp-for="Email" class="form-control rounded-custom" />

                        <span asp-validation-for="Email" class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="Phone" class="form-label fw-semibold">
                        </label>

                        <input asp-for="Phone" class="form-control rounded-custom" />

                        <span asp-validation-for="Phone" class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="PasswordHash" class="form-label fw-semibold">
                            Password
                        </label>

                        <input asp-for="PasswordHash" type="password" class="form-control rounded-custom" />

                        <span asp-validation-for="PasswordHash" class="text-danger">
                        </span>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="RoleId" class="form-label fw-semibold">
                        </label>

                        <select asp-for="RoleId" asp-items="ViewBag.Roles" class="form-select rounded-custom">

                            <option value="">
                                Select Role
                            </option>

                        </select>

                        <span asp-validation-for="RoleId" class="text-danger">
                        </span>

                    </div>

                </div>

                <hr class="my-5" />

                <div class="d-flex justify-content-end gap-2">

                    <a asp-action="Index" class="btn btn-outline-secondary rounded-custom px-4">

                        Cancel

                    </a>

                    <button type="submit" class="btn btn-primary rounded-custom px-5">

                        <i class="bi bi-plus-circle me-2"></i>

                        Create User

                    </button>

                </div>

            </form>

        </div>

    </div>

</section>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}