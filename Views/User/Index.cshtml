@model List<User>

@{
    ViewData["Title"] = "Users";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Users Management</h2>
            <p class="text-muted">Manage all registered users.</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="stat-card">
                <h6>Total Users</h6>
                <h2>@Model.Count()</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <h6>Owners</h6>
                <h2>@Model.Count(x => x.Role?.Name == "Owner")</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <h6>Customers</h6>
                <h2>@Model.Count(x => x.Role?.Name == "Customer")</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <h6>Admins</h6>
                <h2>@Model.Count(x => x.Role?.Name == "Admin")</h2>
            </div>
        </div>
    </div>

    <div class="input-group mb-4">
        <input class="form-control rounded-start-pill" placeholder="Search by name or email" />
        <button class="btn btn-primary rounded-end-pill"><i class="bi bi-search"></i></button>
    </div>

    <div class="card border-0 shadow rounded-4">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Businesses</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var user in Model)
                        {
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td><span class="badge bg-primary">@user.Role?.Name</span></td>
                                <td>@(user.Businesses?.Count ?? 0)</td>
                                <td>
                                    @if (user.IsDeleted)
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@user.Id"
                                       class="btn btn-outline-primary btn-sm">Details</a>
                                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-warning btn-sm">Edit</a>
                                    <a asp-action="Delete" asp-route-id="@user.Id"
                                       class="btn btn-outline-danger btn-sm">Delete</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">No users found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    body {
        background: #f8fafc
    }

    .stat-card {
        background: #fff;
        border-radius: 20px;
        padding: 24px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0, 0, 0, .08)
    }

    .card {
        border-radius: 20px
    }

    .table th,
    .table td {
        padding: 18px
    }

    .badge {
        border-radius: 999px;
        padding: .5rem .9rem
    }

    .btn-primary {
        background: #2563eb;
        border-color: #2563eb
    }
</style>