@using GraduationProject.Models
@model Business


@{
    ViewData["Title"] = "Edit Business";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Edit Business</h2>
            <p class="text-muted">Update business information and manage images.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <form asp-action="Edit" method="post">

        <input asp-for="Id" type="hidden" />

        <div class="row g-4">

            <div class="col-lg-8">

                <div class="card border-0 shadow rounded-4">

                    <div class="card-header bg-white border-0">
                        <h4 class="fw-bold mb-0">Business Information</h4>
                    </div>

                    <div class="card-body">

                        <div class="mb-3">
                            <label asp-for="BusinessName" class="form-label"></label>
                            <input asp-for="BusinessName" class="form-control rounded-3" />
                            <span asp-validation-for="BusinessName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Address" class="form-label"></label>
                            <input asp-for="Address" class="form-control rounded-3" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" asp-items="Html.GetEnumSelectList<BusinessStatus>()"
                                    class="form-select rounded-3">
                            </select>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" rows="6" class="form-control rounded-3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                    </div>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="card border-0 shadow rounded-4">

                    <div class="card-header bg-white border-0">
                        <h5 class="fw-bold">Business Images</h5>
                    </div>

                    <div class="card-body">

                        @if (Model.Images.Any())
                        {
                            foreach (var image in Model.Images)
                            {
                                <div class="image-item mb-3">

                                    <img src="@image.ImagePath" class="img-fluid rounded-3" />

                                    <div class="d-grid mt-2">
                                        <a asp-action="DeleteImage" asp-route-id="@image.Id"
                                           class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-trash"></i> Delete
                                        </a>
                                    </div>

                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-light border text-center">
                                No images found.
                            </div>
                        }

                        <hr />

                        <label class="form-label fw-semibold">
                            Add Image URL
                        </label>

                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="https://..." />
                            <button type="button" class="btn btn-primary">
                                Add
                            </button>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="mt-4 d-flex gap-2">

            <button class="btn btn-primary px-4">
                <i class="bi bi-floppy"></i>
                Save Changes
            </button>

            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info">
                Details
            </a>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Cancel
            </a>

        </div>

    </form>

</div>

<style>
    body {
        background: #f8fafc;
    }

    .card {
        border-radius: 22px;
    }

    .form-control,
    .form-select,
    .btn {
        border-radius: 14px;
    }

    .image-item img {
        width: 100%;
        height: 170px;
        object-fit: cover;
        box-shadow: 0 6px 18px rgba(0, 0, 0, .08);
    }

    .card {
        box-shadow: 0 10px 25px rgba(0, 0, 0, .08) !important;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}