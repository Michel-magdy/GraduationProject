@using GraduationProject.Models

@model List<Business>

@{
    ViewData["Title"] = "Businesses";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Business Management</h2>
            <p class="text-muted">Manage all registered businesses</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle"></i> Add Business
        </a>
    </div>

    @{
        var pending = Model.Count(x => x.Status == BusinessStatus.Pending);
        var approved = Model.Count(x => x.Status == BusinessStatus.Approved);
        var rejected = Model.Count(x => x.Status == BusinessStatus.Rejected);
    }

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="glass-card p-4 text-center">
                <h6>Total</h6>
                <h2>@Model.Count()</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-4 text-center">
                <h6>Pending</h6>
                <h2 class="text-warning">@pending</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-4 text-center">
                <h6>Approved</h6>
                <h2 class="text-success">@approved</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="glass-card p-4 text-center">
                <h6>Rejected</h6>
                <h2 class="text-danger">@rejected</h2>
            </div>
        </div>
    </div>
    @* 
    <div class="input-group mb-4">
        <input class="form-control rounded-start-pill" placeholder="Search business..." />
        <button class="btn btn-primary rounded-end-pill"><i class="bi bi-search"></i></button>
    </div> *@

    <div class="row g-4">
        @foreach (var business in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card business-card border-0 h-100">
                    <img class="business-img"
                         src="@(business.Images.FirstOrDefault()?.ImagePath ?? "/images/no-image.png")" />

                    <div class="card-body">
                        <h4>@business.BusinessName</h4>
                        <p class="text-muted"><i class="bi bi-geo-alt"></i> @business.Address</p>
                        <p><strong>Owner:</strong> @business.Owner?.FullName</p>

                        @if (business.Status == BusinessStatus.Pending)
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                        else if (business.Status == BusinessStatus.Approved)
                        {
                            <span class="badge bg-success">Approved</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Rejected</span>
                        }

                        <div class="row text-center mt-4">
                            <div class="col"><strong>@business.Hotels.Count</strong><br /><small>Hotels</small></div>
                            <div class="col"><strong>@business.Restaurants.Count</strong><br /><small>Restaurants</small>
                            </div>
                            <div class="col"><strong>@business.Tours.Count</strong><br /><small>Tours</small></div>
                            <div class="col"><strong>@business.CarRentals.Count</strong><br /><small>Cars</small></div>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-0 d-grid gap-2">
                        <a asp-action="Details" asp-route-id="@business.Id" class="btn btn-outline-primary">Details</a>

                        @if (business.Status == BusinessStatus.Pending)
                        {
                            <div class="d-flex gap-2">
                                <a asp-action="Approve" asp-route-id="@business.Id"
                                   class="btn btn-success flex-fill">Approve</a>
                                <a asp-action="Reject" asp-route-id="@business.Id" class="btn btn-warning flex-fill">Reject</a>
                            </div>
                        }

                        <a asp-action="Delete" asp-route-id="@business.Id" class="btn btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    body {
        background: #f8fafc;
    }

    .glass-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, .08);
    }

    .business-card {
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(0, 0, 0, .08);
        transition: .3s;
    }

    .business-card:hover {
        transform: translateY(-8px);
    }

    .business-img {
        height: 220px;
        object-fit: cover;
    }

    .btn-primary {
        background: #2563eb;
        border-color: #2563eb;
    }

    .badge {
        padding: .6rem 1rem;
        border-radius: 999px;
    }
</style>