@model IEnumerable<Business>

@{
    ViewData["Title"] = "Businesses";
}

<section class="management-page position-relative overflow-hidden">
    <div class="blur-circle bg-primary-gradient position-absolute top-0 start-0 translate-middle"></div>
    <div class="container position-relative z-index-2">
        <div class="management-hero d-flex flex-column flex-lg-row justify-content-between align-items-lg-end">
            <div>
                <span class="management-eyebrow">Partners</span>
                <h1 class="management-title">Businesses</h1>
                <p class="management-subtitle">Review partner profiles and the travel services connected to each business.</p>
            </div>
            <a asp-controller="Business" asp-action="Add" class="btn btn-primary rounded-custom px-4 py-2 fw-semibold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Add Business
            </a>
        </div>

        <div class="management-card">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table management-table align-middle">
                        <thead>
                            <tr>
                                <th>Business</th>
                                <th>Owner</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Services</th>
                                <th>Media</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var business in Model)
                            {
                                var serviceCount = business.Hotels.Count + business.Restaurants.Count + business.CarRentals.Count + business.Tours.Count;
                                var statusClass = business.Status.Equals("approved", StringComparison.OrdinalIgnoreCase) || business.Status.Equals("active", StringComparison.OrdinalIgnoreCase)
                                    ? "approved"
                                    : "pending";

                                <tr>
                                    <td data-label="Business">
                                        <div class="entity-name">@business.BusinessName</div>
                                        <div class="entity-muted">@business.Address</div>
                                    </td>
                                    <td data-label="Owner">@(business.Owner?.FullName ?? $"Owner #{business.OwnerId}")</td>
                                    <td data-label="Type">@business.BusinessType</td>
                                    <td data-label="Status">
                                        <span class="status-pill @statusClass">
                                            <i class="bi bi-circle-fill small"></i>@business.Status
                                        </span>
                                    </td>
                                    <td data-label="Services">@serviceCount</td>
                                    <td data-label="Media">@business.Images.Count images / @business.Reviews.Count reviews</td>
                                    <td data-label="Actions" class="text-lg-end">
                                        <div class="action-group">
                                            <a asp-controller="Business" asp-action="Details" asp-route-id="@business.Id" class="btn btn-outline-primary btn-sm rounded-custom">Details</a>
                                            <a asp-controller="Business" asp-action="Edit" asp-route-id="@business.Id" class="btn btn-primary btn-sm rounded-custom">Edit</a>
                                            <form asp-controller="Business" asp-action="Delete" asp-route-id="@business.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-custom">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-buildings-fill"></i>
                    <h2 class="h5 fw-bold mt-3 mb-2">No businesses yet</h2>
                    <p class="text-muted mb-0">Partner businesses will appear here when your controller provides them.</p>
                </div>
            }
        </div>
    </div>
</section>
