@model Business

@{
    ViewData["Title"] = "Business Details";
    var statusClass = Model.Status.Equals("approved", StringComparison.OrdinalIgnoreCase) || Model.Status.Equals("active", StringComparison.OrdinalIgnoreCase)
        ? "approved"
        : "pending";
}

<section class="management-page position-relative overflow-hidden">
    <div class="blur-circle bg-primary-gradient position-absolute top-0 start-0 translate-middle"></div>
    <div class="container position-relative z-index-2">
        <div class="management-hero d-flex flex-column flex-lg-row justify-content-between align-items-lg-end">
            <div>
                <span class="management-eyebrow">Business</span>
                <h1 class="management-title">@Model.BusinessName</h1>
                <p class="management-subtitle">@Model.Description</p>
            </div>
            <div class="action-group mt-3 mt-lg-0">
                <a asp-controller="Business" asp-action="Index" class="btn btn-outline-primary rounded-custom px-4 py-2 fw-semibold">Back</a>
                <a asp-controller="Business" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary rounded-custom px-4 py-2 fw-semibold shadow-sm">Edit</a>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-5">
                <div class="management-card p-4 h-100">
                    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
                        <div>
                            <div class="entity-muted">Owner</div>
                            <div class="entity-name">@(Model.Owner?.FullName ?? $"Owner #{Model.OwnerId}")</div>
                        </div>
                        <span class="status-pill @statusClass">
                            <i class="bi bi-circle-fill small"></i>@Model.Status
                        </span>
                    </div>

                    <dl class="row mb-0 g-3">
                        <dt class="col-sm-4 entity-muted">Type</dt>
                        <dd class="col-sm-8 mb-0">@Model.BusinessType</dd>

                        <dt class="col-sm-4 entity-muted">Address</dt>
                        <dd class="col-sm-8 mb-0">@Model.Address</dd>

                        <dt class="col-sm-4 entity-muted">Images</dt>
                        <dd class="col-sm-8 mb-0">@Model.Images.Count</dd>

                        <dt class="col-sm-4 entity-muted">Reviews</dt>
                        <dd class="col-sm-8 mb-0">@Model.Reviews.Count</dd>
                    </dl>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="management-card p-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
                        <div>
                            <h2 class="h5 fw-bold mb-1">Business Images</h2>
                            <p class="entity-muted mb-0">Images are controlled from this business page.</p>
                        </div>
                        <form asp-controller="Business" asp-action="AddImage" method="post" class="business-image-form">
                            <input type="hidden" name="businessId" value="@Model.Id" />
                            <input type="hidden" name="returnAction" value="Details" />
                            <input name="imagePath" class="form-control rounded-custom" placeholder="Image path or URL" />
                            <button type="submit" class="btn btn-primary rounded-custom fw-semibold">
                                <i class="bi bi-plus-lg me-1"></i>Add
                            </button>
                        </form>
                    </div>

                    @if (Model.Images.Any())
                    {
                        <div class="business-image-grid">
                            @foreach (var image in Model.Images)
                            {
                                <div class="business-image-tile">
                                    <img src="@image.ImagePath" alt="@Model.BusinessName image" />
                                    <div class="business-image-body">
                                        <span class="entity-muted">@image.ImagePath</span>
                                        <form asp-controller="Business" asp-action="DeleteImage" method="post">
                                            <input type="hidden" name="businessId" value="@Model.Id" />
                                            <input type="hidden" name="imageId" value="@image.Id" />
                                            <input type="hidden" name="returnAction" value="Details" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-custom">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-images"></i>
                            <h2 class="h5 fw-bold mt-3 mb-2">No images yet</h2>
                            <p class="text-muted mb-0">Add image paths here instead of managing a separate image page.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
