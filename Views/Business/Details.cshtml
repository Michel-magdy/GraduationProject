@using GraduationProject.Models
@model Business

@{
    ViewData["Title"] = "Business Details";
}

<div class="container py-4">

    <a asp-action="Index" class="btn btn-outline-secondary mb-4">
        <i class="bi bi-arrow-left"></i> Back
    </a>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">

        <img src="@(Model.Images.FirstOrDefault()?.ImagePath ?? "/images/no-image.png")"
             style="height:350px;object-fit:cover;" class="w-100" />

        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center flex-wrap">

                <div>
                    <h2 class="fw-bold">@Model.BusinessName</h2>

                    <p class="text-muted mb-1">
                        <i class="bi bi-geo-alt-fill"></i>
                        @Model.Address
                    </p>

                    <p class="mb-0">
                        <i class="bi bi-person-fill"></i>
                        <strong>Owner:</strong> @Model.Owner?.FullName
                    </p>
                </div>

                <div>
                    @if (Model.Status == BusinessStatus.Pending)
                    {
                        <span class="badge bg-warning text-dark fs-6">Pending</span>
                    }
                    else if (Model.Status == BusinessStatus.Approved)
                    {
                        <span class="badge bg-success fs-6">Approved</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6">Rejected</span>
                    }
                </div>

            </div>

        </div>

    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-2">
            <div class="info-card">
                <h3>@Model.Images.Count</h3><span>Images</span>
            </div>
        </div>
        <div class="col-md-2">
            <div class="info-card">
                <h3>@Model.Hotels.Count</h3><span>Hotels</span>
            </div>
        </div>
        <div class="col-md-2">
            <div class="info-card">
                <h3>@Model.Restaurants.Count</h3><span>Restaurants</span>
            </div>
        </div>
        <div class="col-md-2">
            <div class="info-card">
                <h3>@Model.Tours.Count</h3><span>Tours</span>
            </div>
        </div>
        <div class="col-md-2">
            <div class="info-card">
                <h3>@Model.CarRentals.Count</h3><span>Cars</span>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-white border-0">
            <h4>Description</h4>
        </div>
        <div class="card-body">
            <p>@Model.Description</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-white border-0">
            <h4>Gallery</h4>
        </div>

        <div class="card-body">

            <div class="row g-3">

                @foreach (var image in Model.Images)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">

                        <div class="gallery-card">

                            <img src="@image.ImagePath" class="gallery-img" />

                        </div>

                    </div>
                }

            </div>

        </div>

    </div>

    <div class="row g-4">

        <div class="col-md-6">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-header bg-white border-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Hotels</h5>
                        <a asp-controller="Hotel" asp-action="Index" asp-route-businessId="@Model.Id"
                           class="btn btn-sm btn-primary">Manage</a>
                    </div>
                </div>

                <ul class="list-group list-group-flush">

                    @foreach (var hotel in Model.Hotels)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>@hotel.Name</span>
                            <a asp-controller="Hotel" asp-action="Details" asp-route-id="@hotel.Id" class="btn btn-sm btn-outline-primary">View</a>
                        </li>
                    }

                </ul>

            </div>

        </div>

        <div class="col-md-6">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-header bg-white border-0">
                    <h5>Restaurants</h5>
                </div>

                <ul class="list-group list-group-flush">

                    @foreach (var restaurant in Model.Restaurants)
                    {
                        <li class="list-group-item d-flex justify-content-between">
                            <span>@restaurant.Name</span>
                            <a asp-controller="Restaurant" asp-action="Details" asp-route-id="@restaurant.Id" class="btn btn-sm btn-outline-primary">View</a>
                        </li>
                    }

                </ul>

            </div>

        </div>

        <div class="col-md-6">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-header bg-white border-0">
                    <h5>Tours</h5>
                </div>

                <ul class="list-group list-group-flush">

                    @foreach (var tour in Model.Tours)
                    {
                        <li class="list-group-item">@tour.Name</li>
                    }

                </ul>

            </div>

        </div>

        <div class="col-md-6">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-header bg-white border-0">
                    <h5>Car Rentals</h5>
                </div>

                <ul class="list-group list-group-flush">

                    @foreach (var car in Model.CarRentals)
                    {
                        <li class="list-group-item">@car.Brand @car.Model</li>
                    }

                </ul>

            </div>

        </div>

    </div>

    <div class="d-flex gap-2 mt-4">

        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>

        @if (Model.Status == BusinessStatus.Pending)
        {
            <form asp-action="Approve" asp-route-id="@Model.Id" method="post" class="d-inline">
                <button type="submit" class="btn btn-success">Approve</button>
            </form>
            <form asp-action="Reject" asp-route-id="@Model.Id" method="post" class="d-inline">
                <button type="submit" class="btn btn-warning">Reject</button>
            </form>
        }


        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            <button type="submit" class="btn btn-outline-danger w-100">Delete</button>
        </form>
    </div>
</div>

<style>
    body {
        background: #f8fafc
    }

    .info-card {
        background: #fff;
        border-radius: 18px;
        padding: 25px;
        text-align: center;
        box-shadow: 0 8px 20px rgba(0, 0, 0, .08)
    }

    .info-card h3 {
        font-weight: 700;
        margin: 0
    }

    .gallery-card {
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 6px 18px rgba(0, 0, 0, .08)
    }

    .gallery-img {
        width: 100%;
        height: 180px;
        object-fit: cover
    }
</style>
