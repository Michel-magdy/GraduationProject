@model Business
@{
    ViewData["Title"] = "Register Business";
}


<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Register New Business</h2>
            <p class="text-muted">Create a business before adding hotels, restaurants, tours or cars.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill"><i class="bi bi-arrow-left"></i> Back</a>
    </div>

    <form asp-action="Create" method="post">
        <div class="card border-0 shadow rounded-4">
            <div class="card-body p-4">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="BusinessName" class="form-label"></label>
                        <input asp-for="BusinessName" class="form-control rounded-3" />
                        <span asp-validation-for="BusinessName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control rounded-3" />
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="OwnerId" class="form-label"></label>

                        <select asp-for="OwnerId" asp-items="ViewBag.Owners" class="form-select">
                        </select>

                        <span asp-validation-for="OwnerId" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" rows="6" class="form-control rounded-3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i>
                    The business will be submitted as <strong>Pending</strong> until approved by an administrator.
                </div>

                <h5 class="mt-4 mb-3">Business Images</h5>

                <div id="images">
                    <div class="input-group mb-3">
                        <input type="text" name="ImageUrls" class="form-control"
                               placeholder="https://example.com/image.jpg" />
                        <button class="btn btn-outline-primary addImage" type="button"><i
                            class="bi bi-plus-circle"></i></button>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button class="btn btn-primary"><i class="bi bi-check-circle"></i> Register Business</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>

                </div>
            </div>
        </form>
    </div>

    <style>
        body {
            background: #f8fafc
        }

        .card {
            border-radius: 22px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, .08) !important
        }

        .form-control,
        .btn {
            border-radius: 14px
        }

        .btn-primary {
            background: #2563eb;
            border-color: #2563eb
        }
    </style>

    <script>
        document.addEventListener('click', function (e) {
            if (e.target.closest('.addImage')) {
                const c = document.getElementById('images');
                const d = document.createElement('div');
                d.className = 'input-group mb-3';
                d.innerHTML = '<input type="text" name="ImageUrls" class="form-control" placeholder="https://example.com/image.jpg"/><button type="button" class="btn btn-outline-danger removeImage"><i class="bi bi-trash"></i></button>';
                c.appendChild(d);
            }
            if (e.target.closest('.removeImage')) {
                e.target.closest('.input-group').remove();
            }
        });
    </script>