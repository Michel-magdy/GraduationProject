@model Restaurant

@{
    ViewData["Title"] = "Restaurant Details";
    var userRole = Context.Session.GetString("UserRole");
    var isManager = userRole == "Admin" || userRole == "Owner";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left"></i> Back
        </a>

        @if (isManager)
        {
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="bi bi-pencil"></i> Edit
                </a>

                <a asp-controller="Table" asp-action="Index" asp-route-restaurantId="@Model.Id" class="btn btn-success">
                    <i class="bi bi-door-open"></i> Manage Tables
                </a>

                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Delete
                    </button>
                </form>
            </div>
        }
    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">

        <img src="@(Model.Images.FirstOrDefault()?.ImagePath ?? "/images/no-image.png")" class="hero-image" />

        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center flex-wrap">

                <div>
                    <h2 class="fw-bold">@Model.Name</h2>

                    <p class="text-muted mb-1">
                        <i class="bi bi-building"></i>
                        @Model.Business?.BusinessName
                    </p>

                    <p class="text-muted">
                        <i class="bi bi-geo-alt-fill"></i>
                        @Model.Location
                    </p>
                </div>

            </div>

        </div>

    </div>

    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="stat-card">
                <h3>@Model.Tables.Count</h3>
                <span>Total Tables</span>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <h3>@Model.Images.Count</h3>
                <span>Images</span>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <h3>@Model.Tables.Count(r => r.Status == TableStatus.Available)</h3>
                <span>Available</span>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <h3>@Model.Tables.Count(r => r.Status == TableStatus.Occupied)</h3>
                <span>Occupied</span>
            </div>
        </div>

    </div>

    <div class="card border-0 shadow rounded-4 mb-4">
        <div class="card-header bg-white border-0">
            <h4>Description</h4>
        </div>

        <div class="card-body">
            <p>@Model.Description</p>
        </div>
    </div>

    <div class="card border-0 shadow rounded-4 mb-4">

        <div class="card-header bg-white border-0">
            <h4>Gallery</h4>
        </div>

        <div class="card-body">

            <div class="row g-3">

                @foreach (var image in Model.Images)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <img src="@image.ImagePath" class="gallery-image" />
                    </div>
                }

            </div>

        </div>

    </div>

    <div class="card border-0 shadow rounded-4">

        <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
            <h4>Tables</h4>

            @if (isManager)
            {
                <a asp-controller="Table" asp-action="Create" asp-route-restaurantId="@Model.Id"
                   class="btn btn-primary btn-sm">
                    <i class="bi bi-plus-circle"></i> Add Table
                </a>
            }
        </div>

        <div class="card-body p-0">

            <table class="table table-hover mb-0 align-middle">

                <thead class="table-light">
                    <tr>
                        <th>Table</th>
                        <th>Capacity</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var table in Model.Tables)
                    {
                        <tr>

                            <td>@table.TableNumber</td>

                            <td>@table.Capacity</td>

                            <td>
                                @if (table.Status == TableStatus.Available)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Booked</span>
                                }
                            </td>

                            <td>
                                <a asp-controller="Table" asp-action="Details" asp-route-id="@table.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    View
                                </a>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

    <!-- Reviews -->
    <div class="card border-0 shadow rounded-4 mt-4 mb-4">
        <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center pt-3">
            <h4 class="fw-bold mb-0">Reviews (@Model.Reviews.Count)</h4>
            @if (Context.Session.GetInt32("UserId") != null && !isManager)
            {
                <a asp-controller="Review" asp-action="AddRestaurantReview" asp-route-restaurantId="@Model.Id" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i> Write a Review
                </a>
            }
        </div>
        <div class="card-body">
            @if (Model.Reviews.Any())
            {
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Rating</th>
                            <th>Comment</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var review in Model.Reviews.OrderByDescending(r => r.CreatedAt))
                        {
                            <tr>
                                <td>@review.User?.FullName</td>
                                <td>
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= review.Rate)
                                        {
                                            <span class="text-warning">★</span>
                                        }
                                        else
                                        {
                                            <span class="text-secondary">☆</span>
                                        }
                                    }
                                </td>
                                <td>@review.Comment</td>
                                <td>@review.CreatedAt.ToShortDateString()</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p class="text-muted mb-0">No reviews yet.</p>
            }
        </div>
    </div>

</div>

<style>
    body {
        background: #f8fafc;
    }

    .hero-image {
        width: 100%;
        height: 340px;
        object-fit: cover;
    }

    .stat-card {
        background: #fff;
        border-radius: 20px;
        padding: 24px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0, 0, 0, .08);
    }

    .gallery-image {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-radius: 18px;
        box-shadow: 0 6px 18px rgba(0, 0, 0, .08);
    }

    .card {
        border-radius: 22px;
    }
</style>
