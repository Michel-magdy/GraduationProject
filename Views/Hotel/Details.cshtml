@model Hotel

@{
    ViewData["Title"] = "Hotel Details";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left"></i> Back
        </a>

        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                <i class="bi bi-pencil"></i> Edit
            </a>

            <a asp-controller="Room" asp-action="Index" asp-route-hotelId="@Model.Id" class="btn btn-success">
                <i class="bi bi-door-open"></i> Manage Rooms
            </a>

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-trash"></i> Delete
                </button>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">

        <img src="@(Model.Images.FirstOrDefault()?.ImagePath ?? "/images/no-image.png")" class="hero-image" />

        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center flex-wrap">

                <div>
                    <h2 class="fw-bold">@Model.Name</h2>

                    <p class="text-muted mb-1">
                        <i class="bi bi-building"></i>
                        @Model.Business?.BusinessName
                    </p>

                    <p class="text-muted">
                        <i class="bi bi-geo-alt-fill"></i>
                        @Model.Location
                    </p>
                </div>

            </div>

        </div>

    </div>

    <div class="row g-3 mb-4">

        <div class="col-md-3">
            <div class="stat-card">
                <h3>@Model.Rooms.Count</h3>
                <span>Total Rooms</span>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <h3>@Model.Images.Count</h3>
                <span>Images</span>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <h3>@Model.Rooms.Count(r => r.status == RoomStatus.Available)</h3>
                <span>Available</span>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-card">
                <h3>@Model.Rooms.Count(r => r.status == RoomStatus.Occupied)</h3>
                <span>Occupied</span>
            </div>
        </div>

    </div>

    <div class="card border-0 shadow rounded-4 mb-4">
        <div class="card-header bg-white border-0">
            <h4>Description</h4>
        </div>

        <div class="card-body">
            <p>@Model.Description</p>
        </div>
    </div>

    <div class="card border-0 shadow rounded-4 mb-4">

        <div class="card-header bg-white border-0">
            <h4>Gallery</h4>
        </div>

        <div class="card-body">

            <div class="row g-3">

                @foreach (var image in Model.Images)
                {
                    <div class="col-lg-3 col-md-4 col-sm-6">
                        <img src="@image.ImagePath" class="gallery-image" />
                    </div>
                }

            </div>

        </div>

    </div>

    <div class="card border-0 shadow rounded-4">

        <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center">
            <h4>Rooms</h4>

            <a asp-controller="Room" asp-action="Create" asp-route-hotelId="@Model.Id" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-circle"></i> Add Room
            </a>
        </div>

        <div class="card-body p-0">

            <table class="table table-hover mb-0 align-middle">

                <thead class="table-light">
                    <tr>
                        <th>Room</th>
                        <th>Capacity</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var room in Model.Rooms)
                    {
                        <tr>

                            <td>@room.RoomNumber</td>

                            <td>@room.Capacity</td>

                            <td>@room.Price.ToString("C")</td>

                            <td>
                                @if (room.status == RoomStatus.Available)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Booked</span>
                                }
                            </td>

                            <td>
                                <a asp-controller="Room" asp-action="Details" asp-route-id="@room.Id"
                                   class="btn btn-outline-primary btn-sm">
                                    View
                                </a>
                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>

<style>
    body {
        background: #f8fafc;
    }

    .hero-image {
        width: 100%;
        height: 340px;
        object-fit: cover;
    }

    .stat-card {
        background: #fff;
        border-radius: 20px;
        padding: 24px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0, 0, 0, .08);
    }

    .gallery-image {
        width: 100%;
        height: 180px;
        object-fit: cover;
        border-radius: 18px;
        box-shadow: 0 6px 18px rgba(0, 0, 0, .08);
    }

    .card {
        border-radius: 22px;
    }
</style>