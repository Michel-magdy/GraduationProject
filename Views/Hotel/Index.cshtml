@model List<Hotel>

@{
    ViewData["Title"] = "Hotels";
    var businessId = ViewBag.BusinessId as int?;
    var isBusinessScoped = businessId.HasValue;
    var userRole = Context.Session.GetString("UserRole");
    var isManager = userRole == "Admin" || userRole == "Owner";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">@ViewBag.BusinessName Hotels</h2>
            <p class="text-muted">@(isManager ? "Manage hotels belonging to this business." : "Explore available hotels.")</p>
        </div>

        <div>
            @if (isBusinessScoped)
            {
                <a asp-controller="Business" asp-action="Details" asp-route-id="@businessId"
                   class="btn btn-outline-secondary rounded-pill me-2">
                    <i class="bi bi-arrow-left"></i> Business
                </a>

                @if (isManager)
                {
                    <a asp-action="Create" asp-route-businessId="@businessId" class="btn btn-primary rounded-pill">
                        <i class="bi bi-plus-circle"></i> Add Hotel
                    </a>
                }
            }
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="stat-card">
                <h6>Total Hotels</h6>
                <h2>@Model.Count()</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <h6>Total Rooms</h6>
                <h2>@Model.Sum(x => x.Rooms.Count)</h2>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <h6>Total Images</h6>
                <h2>@Model.Sum(x => x.Images.Count)</h2>
            </div>
        </div>
    </div>
    @* 
    <div class="input-group mb-4">
        <input class="form-control rounded-start-pill" placeholder="Search hotel..." />
        <button class="btn btn-primary rounded-end-pill"><i class="bi bi-search"></i></button>
    </div> *@

    <div class="row g-4">
        @foreach (var hotel in Model)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card hotel-card border-0 h-100">

                    <img src="@(hotel.Images.FirstOrDefault()?.ImagePath ?? "/images/no-image.png")" class="hotel-image" />

                    <div class="card-body">
                        <h4>@hotel.Name</h4>
                        <p class="text-muted"><i class="bi bi-geo-alt-fill"></i> @hotel.Location</p>
                        <p>@hotel.Description</p>

                        <div class="row text-center mt-3">
                            <div class="col"><strong>@hotel.Rooms.Count</strong><br /><small>Rooms</small></div>
                            <div class="col"><strong>@hotel.Images.Count</strong><br /><small>Images</small></div>
                        </div>
                    </div>

                    <div class="card-footer bg-white border-0 d-grid gap-2">
                        <a asp-action="Details" asp-route-id="@hotel.Id" class="btn btn-outline-primary">Details</a>
                        @if (isManager)
                        {
                            <a asp-controller="Room" asp-action="Index" asp-route-hotelId="@hotel.Id"
                               class="btn btn-primary">Manage Rooms</a>
                            <div class="d-flex gap-2">
                                <a asp-action="Edit" asp-route-id="@hotel.Id" class="btn btn-outline-warning flex-fill">Edit</a>

                                <form asp-action="Delete" asp-route-id="@hotel.Id" method="post">
                                    <button type="submit" class="btn btn-outline-danger w-100">Delete</button>
                                </form>
                            </div>
                        }
                    </div>

                </div>
            </div>
        }
    </div>

</div>

<style>
    body {
        background: #f8fafc
    }

    .stat-card {
        background: #fff;
        border-radius: 20px;
        padding: 24px;
        text-align: center;
        box-shadow: 0 10px 25px rgba(0, 0, 0, .08)
    }

    .hotel-card {
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0, 0, 0, .08);
        transition: .3s
    }

    .hotel-card:hover {
        transform: translateY(-6px)
    }

    .hotel-image {
        width: 100%;
        height: 220px;
        object-fit: cover
    }

    .btn-primary {
        background: #2563eb;
        border-color: #2563eb
    }
</style>
