@model IEnumerable<Tour>

@{
    ViewData["Title"] = "Tours";
}

<section class="management-page position-relative overflow-hidden">
    <div class="blur-circle bg-primary-gradient position-absolute top-0 start-0 translate-middle"></div>
    <div class="container position-relative z-index-2">
        <div class="management-hero d-flex flex-column flex-lg-row justify-content-between align-items-lg-end">
            <div>
                <span class="management-eyebrow">Experiences</span>
                <h1 class="management-title">Tours</h1>
                <p class="management-subtitle">Manage guided trips, participant capacity, prices, and bookings.</p>
            </div>
            <a asp-controller="Tour" asp-action="Add" class="btn btn-primary rounded-custom px-4 py-2 fw-semibold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Add Tour
            </a>
        </div>

        <div class="management-card">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table management-table align-middle">
                        <thead>
                            <tr>
                                <th>Tour</th>
                                <th>Business</th>
                                <th>Date</th>
                                <th>Price</th>
                                <th>Participants</th>
                                <th>Bookings</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tour in Model)
                            {
                                <tr>
                                    <td data-label="Tour"><div class="entity-name">@tour.Name</div></td>
                                    <td data-label="Business">@(tour.Business?.BusinessName ?? $"Business #{tour.BusinessId}")</td>
                                    <td data-label="Date">@tour.TripDate.ToString("MMM dd, yyyy")</td>
                                    <td data-label="Price">@tour.Price.ToString("C")</td>
                                    <td data-label="Participants">@tour.CurrentParticipants / @tour.MaxParticipants</td>
                                    <td data-label="Bookings">@tour.TourBookings.Count</td>
                                    <td data-label="Actions" class="text-lg-end">
                                        <div class="action-group">
                                            <a asp-controller="Tour" asp-action="Details" asp-route-id="@tour.Id" class="btn btn-outline-primary btn-sm rounded-custom">Details</a>
                                            <a asp-controller="Tour" asp-action="Edit" asp-route-id="@tour.Id" class="btn btn-primary btn-sm rounded-custom">Edit</a>
                                            <form asp-controller="Tour" asp-action="Delete" asp-route-id="@tour.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-custom">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-map-fill"></i>
                    <h2 class="h5 fw-bold mt-3 mb-2">No tours yet</h2>
                    <p class="text-muted mb-0">Tour experiences will appear here once loaded.</p>
                </div>
            }
        </div>
    </div>
</section>
