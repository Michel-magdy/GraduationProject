@model GraduationProject.Models.Tour

@{
    ViewData["Title"] = "Edit Tour";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Edit Tour</h2>
            <p class="text-muted">@Model.Name</p>
        </div>

        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left"></i>
            Back
        </a>
    </div>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">

        <input asp-for="Id" type="hidden" />
        <input asp-for="BusinessId" type="hidden" />

        <div class="row">

            <!-- Tour Information -->

            <div class="col-lg-8">

                <div class="card shadow-sm border-0 mb-4">

                    <div class="card-header fw-bold">
                        Tour Information
                    </div>

                    <div class="card-body">

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control rounded-3" />

                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="TripDate" class="form-label"></label>

                            <input asp-for="TripDate" type="datetime-local" class="form-control rounded-3" />

                            <span asp-validation-for="TripDate" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label"></label>

                            <input asp-for="Price" class="form-control rounded-3" />

                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <div class="row">

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label asp-for="MaxParticipants" class="form-label"></label>

                                    <input asp-for="MaxParticipants" class="form-control rounded-3" />

                                    <span asp-validation-for="MaxParticipants" class="text-danger"></span>

                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="mb-3">

                                    <label asp-for="CurrentParticipants" class="form-label"></label>

                                    <input asp-for="CurrentParticipants" class="form-control rounded-3" />

                                    <span asp-validation-for="CurrentParticipants" class="text-danger"></span>

                                </div>

                            </div>

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Remaining Seats
                            </label>

                            <input class="form-control rounded-3" value="@Model.RemainingSeats" readonly />

                        </div>

                    </div>

                </div>

            </div>


            <!-- Images -->

            <div class="col-lg-4">

                <div class="card border-0 shadow rounded-4">

                    <div class="card-header bg-white border-0">
                        <h5 class="fw-bold">Tour Images</h5>
                    </div>

                    <div class="card-body">

                        <div id="imageContainer">
                            @if (Model.Images.Any())
                            {
                                @for (int i = 0; i < Model.Images.Count; i++)
                                {
                                    <div class="image-item mb-3 border rounded p-3">

                                        <input name="Images[@i].Id" type="hidden" value="@Model.Images[i].Id" />
                                        <input name="Images[@i].TourId" type="hidden" value="@Model.Id" />

                                        <label class="form-label">Image URL</label>

                                        <input name="Images[@i].ImagePath" class="form-control mb-2"
                                               value="@Model.Images[i].ImagePath" />

                                        <img src="@Model.Images[i].ImagePath" class="img-fluid rounded-3"
                                             style="max-height:150px;" />

                                        <button type="button" class="btn btn-outline-danger btn-sm w-100 mt-2 remove-image">
                                            <i class="bi bi-trash"></i> Remove
                                        </button>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="alert alert-light border text-center no-images-msg">
                                    No images found.
                                </div>
                            }
                        </div>

                        <hr />

                        <label class="form-label fw-semibold">
                            Add Image URL
                        </label>

                        <div class="input-group">
                            <input type="text" id="newImageUrl" class="form-control" placeholder="https://..." />
                            <button type="button" id="addImageBtn" class="btn btn-primary">
                                Add
                            </button>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="mt-4 d-flex gap-2">

            <button class="btn btn-primary rounded-pill px-4" type="submit">

                <i class="bi bi-check-circle"></i>
                Save Changes

            </button>

            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary rounded-pill px-4">

                Cancel

            </a>

        </div>

    </form>

</div>


<script>
    function reindexImages() {
        var container = document.getElementById('imageContainer');
        var items = container.querySelectorAll('.image-item');
        items.forEach(function (item, index) {
            var inputs = item.querySelectorAll('input');
            inputs.forEach(function (input) {
                var name = input.getAttribute('name');
                if (name) {
                    input.setAttribute('name', name.replace(/Images\[\d+\]/, 'Images[' + index + ']'));
                }
            });
        });

        var noImagesMsg = container.querySelector('.no-images-msg');
        if (items.length === 0 && !noImagesMsg) {
            var msg = document.createElement('div');
            msg.className = 'alert alert-light border text-center no-images-msg';
            msg.textContent = 'No images found.';
            container.appendChild(msg);
        } else if (items.length > 0 && noImagesMsg) {
            noImagesMsg.remove();
        }
    }

    document.addEventListener("click", function (e) {
        if (e.target.classList.contains("remove-image") || e.target.closest(".remove-image")) {
            var imageItem = e.target.closest(".image-item");
            if (imageItem) {
                imageItem.remove();
                reindexImages();
            }
        }
    });

    document.getElementById('addImageBtn').addEventListener('click', function () {
        var urlInput = document.getElementById('newImageUrl');
        var url = urlInput.value.trim();
        if (!url) return;

        var container = document.getElementById('imageContainer');

        var noImagesMsg = container.querySelector('.no-images-msg');
        if (noImagesMsg) noImagesMsg.remove();

        var index = container.querySelectorAll('.image-item').length;

        var div = document.createElement('div');
        div.className = 'image-item mb-3 border rounded p-3';
        div.innerHTML =
            '<input name="Images[' + index + '].Id" type="hidden" value="0" />' +
            '<input name="Images[' + index + '].RestaurantId" type="hidden" value="@Model.Id" />' +
            '<label class="form-label">Image URL</label>' +
            '<input name="Images[' + index + '].ImagePath" class="form-control mb-2" value="' + url.replace(/"/g, '&quot;') + '" />' +
            '<img src="' + url.replace(/"/g, '&quot;') + '" class="img-fluid rounded-3" style="max-height:150px;" />' +
            '<button type="button" class="btn btn-outline-danger btn-sm w-100 mt-2 remove-image"><i class="bi bi-trash"></i> Remove</button>';

        container.appendChild(div);
        urlInput.value = '';
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
