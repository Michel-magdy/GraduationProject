@model GraduationProject.Models.Room

@{
    ViewData["Title"] = "Delete Room";
}

<div class="container py-4">

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <!-- Danger Header -->
                <div class="delete-header">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <h3 class="mt-2 mb-0">Confirm Deletion</h3>
                </div>

                <div class="card-body p-4 text-center">

                    <p class="text-muted mb-4">
                        Are you sure you want to delete this Room? This action cannot be undone.
                    </p>

                    <!-- Room Summary -->
                    <div class="delete-summary">
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="summary-item">
                                    <span class="summary-label">Room Number</span>
                                    <span class="summary-value">@Model.RoomNumber</span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="summary-item">
                                    <span class="summary-label">Capacity</span>
                                    <span class="summary-value">@Model.Capacity Seats</span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="summary-item">
                                    <span class="summary-label">Status</span>
                                    <span class="summary-value">
                                        @switch (Model.status)
                                        {
                                            case RoomStatus.Available:
                                                <span class="badge bg-success">Available</span>
                                                break;
                                            case RoomStatus.Occupied:
                                                <span class="badge bg-danger">Occupied</span>
                                                break;
                                            case RoomStatus.Maintenance:
                                                <span class="badge bg-warning text-dark">Maintenance</span>
                                                break;
                                        }
                                    </span>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="summary-item">
                                    <span class="summary-label">Restaurant</span>
                                    <span class="summary-value">@(Model.Hotel?.Name ?? "N/A")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (Model.HotelBookings.Any())
                    {
                        <div class="alert alert-warning mt-3 rounded-3">
                            <i class="bi bi-exclamation-circle"></i>
                            This Room has <strong>@Model.HotelBookings.Count booking(s)</strong>.
                            Deleting it may affect related records.
                        </div>
                    }

                    <div class="d-flex gap-2 justify-content-center mt-4">
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="bi bi-trash"></i> Yes, Delete
                            </button>
                        </form>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>

                </div>

            </div>

        </div>
    </div>

</div>

<style>
    body {
        background: #f0f4f8;
    }

    .delete-header {
        background: linear-gradient(135deg, #dc2626, #b91c1c);
        color: white;
        padding: 35px;
        text-align: center;
        font-size: 48px;
    }

    .delete-header h3 {
        font-weight: 700;
    }

    .delete-summary {
        background: #f8fafc;
        border-radius: 16px;
        padding: 20px;
    }

    .summary-item {
        text-align: center;
    }

    .summary-label {
        display: block;
        font-size: .78rem;
        color: #6b7280;
        margin-bottom: 4px;
    }

    .summary-value {
        display: block;
        font-weight: 700;
        color: #1e293b;
        font-size: 1rem;
    }

    .card {
        border-radius: 22px;
    }

    .btn {
        border-radius: 12px;
        font-weight: 500;
    }
</style>
