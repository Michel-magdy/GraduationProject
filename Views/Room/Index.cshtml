@model IEnumerable<Room>

@{
    ViewData["Title"] = "Rooms";
}

<section class="management-page position-relative overflow-hidden">
    <div class="blur-circle bg-teal-gradient position-absolute bottom-0 end-0 translate-middle"></div>
    <div class="container position-relative z-index-2">
        <div class="management-hero d-flex flex-column flex-lg-row justify-content-between align-items-lg-end">
            <div>
                <span class="management-eyebrow">Inventory</span>
                <h1 class="management-title">Rooms</h1>
                <p class="management-subtitle">Manage hotel rooms, nightly prices, capacity, availability, and bookings.</p>
            </div>
            <a asp-controller="Room" asp-action="Add" class="btn btn-primary rounded-custom px-4 py-2 fw-semibold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Add Room
            </a>
        </div>

        <div class="management-card">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table management-table align-middle">
                        <thead>
                            <tr>
                                <th>Room</th>
                                <th>Hotel</th>
                                <th>Capacity</th>
                                <th>Price</th>
                                <th>Status</th>
                                <th>Bookings</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var room in Model)
                            {
                                <tr>
                                    <td data-label="Room"><div class="entity-name">Room @room.RoomNumber</div></td>
                                    <td data-label="Hotel">@(room.Hotel?.Name ?? $"Hotel #{room.HotelId}")</td>
                                    <td data-label="Capacity">@room.Capacity guests</td>
                                    <td data-label="Price">@room.Price.ToString("C")</td>
                                    <td data-label="Status">
                                        <span class="status-pill @(room.Available ? "available" : "unavailable")">
                                            <i class="bi bi-circle-fill small"></i>@(room.Available ? "Available" : "Unavailable")
                                        </span>
                                    </td>
                                    <td data-label="Bookings">@room.HotelBookings.Count</td>
                                    <td data-label="Actions" class="text-lg-end">
                                        <div class="action-group">
                                            <a asp-controller="Room" asp-action="Details" asp-route-id="@room.Id" class="btn btn-outline-primary btn-sm rounded-custom">Details</a>
                                            <a asp-controller="Room" asp-action="Edit" asp-route-id="@room.Id" class="btn btn-primary btn-sm rounded-custom">Edit</a>
                                            <form asp-controller="Room" asp-action="Delete" asp-route-id="@room.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-custom">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-door-open-fill"></i>
                    <h2 class="h5 fw-bold mt-3 mb-2">No rooms yet</h2>
                    <p class="text-muted mb-0">Room inventory will appear here once loaded.</p>
                </div>
            }
        </div>
    </div>
</section>
