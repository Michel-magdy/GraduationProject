@model GraduationProject.Models.Table

@{
    ViewData["Title"] = "Edit Table";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">
                <i class="bi bi-pencil-square text-warning me-2"></i> Edit Table @Model.TableNumber
            </h2>
            <p class="text-muted">
                Update table details for <strong>@ViewBag.RestaurantName</strong>.
            </p>
        </div>
        <a asp-action="Details" asp-route-id="@Model.Id"
           class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left"></i> Back to Details
        </a>
    </div>

    <form asp-action="Edit" method="post">

        <input asp-for="Id" type="hidden" />
        <input asp-for="RestaurantId" type="hidden" />

        <div class="card border-0 shadow rounded-4">
            <div class="card-body p-4">

                <div class="form-section-title mb-3">
                    <i class="bi bi-info-circle text-primary"></i> Table Information
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="TableNumber" class="form-label fw-semibold">Table Number</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-hash"></i>
                            </span>
                            <input asp-for="TableNumber" class="form-control" />
                        </div>
                        <span asp-validation-for="TableNumber" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Capacity" class="form-label fw-semibold">Seating Capacity</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-people"></i>
                            </span>
                            <input asp-for="Capacity" type="number" min="1" max="20" class="form-control" />
                        </div>
                        <span asp-validation-for="Capacity" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Status" class="form-label fw-semibold">Status</label>
                        <select asp-for="Status" asp-items="Html.GetEnumSelectList<TableStatus>()" class="form-select">
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-check-circle"></i> Save Changes
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary">Cancel</a>
                </div>

            </div>
        </div>

    </form>
</div>

<style>
    body {
        background: #f0f4f8;
    }

    .card {
        border-radius: 22px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, .07) !important;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        padding: 10px 14px;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 3px rgba(37, 99, 235, .15);
    }

    .input-group-text {
        border-radius: 12px 0 0 12px;
        border-right: none;
    }

    .input-group .form-control {
        border-radius: 0 12px 12px 0;
    }

    .btn {
        border-radius: 12px;
        font-weight: 500;
    }

    .btn-primary {
        background: #2563eb;
        border-color: #2563eb;
    }

    .btn-primary:hover {
        background: #1d4ed8;
        border-color: #1d4ed8;
    }

    .form-section-title {
        font-weight: 700;
        font-size: 1.05rem;
        color: #1e293b;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
