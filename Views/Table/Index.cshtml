@model IEnumerable<Table>

@{
    ViewData["Title"] = "Tables";
}

<section class="management-page position-relative overflow-hidden">
    <div class="blur-circle bg-teal-gradient position-absolute bottom-0 end-0 translate-middle"></div>
    <div class="container position-relative z-index-2">
        <div class="management-hero d-flex flex-column flex-lg-row justify-content-between align-items-lg-end">
            <div>
                <span class="management-eyebrow">Dining Inventory</span>
                <h1 class="management-title">Tables</h1>
                <p class="management-subtitle">Manage restaurant tables, seating capacity, availability, and reservations.</p>
            </div>
            <a asp-controller="Table" asp-action="Add" class="btn btn-primary rounded-custom px-4 py-2 fw-semibold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Add Table
            </a>
        </div>

        <div class="management-card">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table management-table align-middle">
                        <thead>
                            <tr>
                                <th>Table</th>
                                <th>Restaurant</th>
                                <th>Capacity</th>
                                <th>Status</th>
                                <th>Bookings</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var table in Model)
                            {
                                <tr>
                                    <td data-label="Table"><div class="entity-name">Table @table.TableNumber</div></td>
                                    <td data-label="Restaurant">@(table.Restaurant?.Name ?? $"Restaurant #{table.RestaurantId}")</td>
                                    <td data-label="Capacity">@table.Capacity guests</td>
                                    <td data-label="Status">
                                        <span class="status-pill @(table.Available ? "available" : "unavailable")">
                                            <i class="bi bi-circle-fill small"></i>@(table.Available ? "Available" : "Unavailable")
                                        </span>
                                    </td>
                                    <td data-label="Bookings">@table.RestaurantBookings.Count</td>
                                    <td data-label="Actions" class="text-lg-end">
                                        <div class="action-group">
                                            <a asp-controller="Table" asp-action="Details" asp-route-id="@table.Id" class="btn btn-outline-primary btn-sm rounded-custom">Details</a>
                                            <a asp-controller="Table" asp-action="Edit" asp-route-id="@table.Id" class="btn btn-primary btn-sm rounded-custom">Edit</a>
                                            <form asp-controller="Table" asp-action="Delete" asp-route-id="@table.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-custom">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                    <h2 class="h5 fw-bold mt-3 mb-2">No tables yet</h2>
                    <p class="text-muted mb-0">Dining table records will appear here once loaded.</p>
                </div>
            }
        </div>
    </div>
</section>
