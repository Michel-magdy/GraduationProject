@model IEnumerable<Image>

@{
    ViewData["Title"] = "Images";
}

<section class="management-page position-relative overflow-hidden">
    <div class="blur-circle bg-teal-gradient position-absolute bottom-0 end-0 translate-middle"></div>
    <div class="container position-relative z-index-2">
        <div class="management-hero d-flex flex-column flex-lg-row justify-content-between align-items-lg-end">
            <div>
                <span class="management-eyebrow">Media</span>
                <h1 class="management-title">Images</h1>
                <p class="management-subtitle">Manage uploaded business imagery and asset paths.</p>
            </div>
            <a asp-controller="Image" asp-action="Add" class="btn btn-primary rounded-custom px-4 py-2 fw-semibold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Add Image
            </a>
        </div>

        <div class="management-card">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table management-table align-middle">
                        <thead>
                            <tr>
                                <th>Image</th>
                                <th>Business</th>
                                <th>Path</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var image in Model)
                            {
                                <tr>
                                    <td data-label="Image"><div class="entity-name">Image #@image.Id</div></td>
                                    <td data-label="Business">@(image.Business?.BusinessName ?? $"Business #{image.BusinessId}")</td>
                                    <td data-label="Path"><span class="entity-muted">@image.ImagePath</span></td>
                                    <td data-label="Actions" class="text-lg-end">
                                        <div class="action-group">
                                            <a asp-controller="Image" asp-action="Details" asp-route-id="@image.Id" class="btn btn-outline-primary btn-sm rounded-custom">Details</a>
                                            <a asp-controller="Image" asp-action="Edit" asp-route-id="@image.Id" class="btn btn-primary btn-sm rounded-custom">Edit</a>
                                            <form asp-controller="Image" asp-action="Delete" asp-route-id="@image.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-custom">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-images"></i>
                    <h2 class="h5 fw-bold mt-3 mb-2">No images yet</h2>
                    <p class="text-muted mb-0">Business images will appear here once loaded.</p>
                </div>
            }
        </div>
    </div>
</section>
