@model IEnumerable<Role>

@{
    ViewData["Title"] = "Roles";
}

<section class="management-page position-relative overflow-hidden">
    <div class="blur-circle bg-primary-gradient position-absolute top-0 start-0 translate-middle"></div>
    <div class="container position-relative z-index-2">
        <div class="management-hero d-flex flex-column flex-lg-row justify-content-between align-items-lg-end">
            <div>
                <span class="management-eyebrow">Access</span>
                <h1 class="management-title">Roles</h1>
                <p class="management-subtitle">Organize account types and see how many users are attached to each role.</p>
            </div>
            <a asp-controller="Role" asp-action="Add" class="btn btn-primary rounded-custom px-4 py-2 fw-semibold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Add Role
            </a>
        </div>

        <div class="management-card">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table management-table align-middle">
                        <thead>
                            <tr>
                                <th>Role</th>
                                <th>Users</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in Model)
                            {
                                <tr>
                                    <td data-label="Role"><div class="entity-name">@role.Name</div></td>
                                    <td data-label="Users">@role.Users.Count</td>
                                    <td data-label="Actions" class="text-lg-end">
                                        <div class="action-group">
                                            <a asp-controller="Role" asp-action="Details" asp-route-id="@role.Id" class="btn btn-outline-primary btn-sm rounded-custom">Details</a>
                                            <a asp-controller="Role" asp-action="Edit" asp-route-id="@role.Id" class="btn btn-primary btn-sm rounded-custom">Edit</a>
                                            <form asp-controller="Role" asp-action="Delete" asp-route-id="@role.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-custom">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-person-badge-fill"></i>
                    <h2 class="h5 fw-bold mt-3 mb-2">No roles yet</h2>
                    <p class="text-muted mb-0">Roles will appear here after your controller sends them to this view.</p>
                </div>
            }
        </div>
    </div>
</section>
