@model IEnumerable<TourBooking>

@{
    ViewData["Title"] = "Tour Bookings";
}

<section class="management-page position-relative overflow-hidden">
    <div class="blur-circle bg-primary-gradient position-absolute top-0 start-0 translate-middle"></div>
    <div class="container position-relative z-index-2">
        <div class="management-hero d-flex flex-column flex-lg-row justify-content-between align-items-lg-end">
            <div>
                <span class="management-eyebrow">Experiences</span>
                <h1 class="management-title">Tour Bookings</h1>
                <p class="management-subtitle">Review booked tours, party size, guest details, and totals.</p>
            </div>
            <a asp-controller="TourBooking" asp-action="Add" class="btn btn-primary rounded-custom px-4 py-2 fw-semibold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Add Booking
            </a>
        </div>

        <div class="management-card">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table management-table align-middle">
                        <thead>
                            <tr>
                                <th>Guest</th>
                                <th>Tour</th>
                                <th>Persons</th>
                                <th>Total</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in Model)
                            {
                                <tr>
                                    <td data-label="Guest"><div class="entity-name">@(booking.User?.FullName ?? $"User #{booking.UserId}")</div></td>
                                    <td data-label="Tour">@(booking.Tour?.Name ?? $"Tour #{booking.TourId}")</td>
                                    <td data-label="Persons">@booking.Persons</td>
                                    <td data-label="Total">@booking.TotalPrice.ToString("C")</td>
                                    <td data-label="Actions" class="text-lg-end">
                                        <div class="action-group">
                                            <a asp-controller="TourBooking" asp-action="Details" asp-route-id="@booking.Id" class="btn btn-outline-primary btn-sm rounded-custom">Details</a>
                                            <a asp-controller="TourBooking" asp-action="Edit" asp-route-id="@booking.Id" class="btn btn-primary btn-sm rounded-custom">Edit</a>
                                            <form asp-controller="TourBooking" asp-action="Delete" asp-route-id="@booking.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-outline-danger btn-sm rounded-custom">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-ticket-perforated-fill"></i>
                    <h2 class="h5 fw-bold mt-3 mb-2">No tour bookings yet</h2>
                    <p class="text-muted mb-0">Tour bookings will appear here once loaded.</p>
                </div>
            }
        </div>
    </div>
</section>
