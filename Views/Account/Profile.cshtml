@model GraduationProject.Models.User

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-4">

    <!-- Profile Header -->
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4">

        <div class="profile-header">
            <div class="profile-avatar">
                <i class="bi bi-person-fill"></i>
            </div>
            <h2 class="fw-bold text-white mt-3 mb-1">@Model.FullName</h2>
            <span class="profile-role-badge">
                <i class="bi bi-shield-check"></i> @(Model.Role?.Name ?? "Customer")
            </span>
        </div>

        <div class="card-body p-4">
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="profile-stat">
                        <i class="bi bi-envelope text-primary"></i>
                        <span class="stat-label">Email</span>
                        <span class="stat-value">@Model.Email</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="profile-stat">
                        <i class="bi bi-telephone text-success"></i>
                        <span class="stat-label">Phone</span>
                        <span class="stat-value">@(string.IsNullOrEmpty(Model.Phone) ? "Not set" : Model.Phone)</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="profile-stat">
                        <i class="bi bi-calendar text-info"></i>
                        <span class="stat-label">Joined</span>
                        <span class="stat-value">@Model.CreatedAt.ToString("MMM dd, yyyy")</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="profile-stat">
                        <i class="bi bi-bookmark-check text-warning"></i>
                        <span class="stat-label">Total Bookings</span>
                        <span class="stat-value">
                            @(Model.HotelBookings.Count + Model.RestaurantBookings.Count +
                              Model.CarRentalBookings.Count + Model.TourBookings.Count)
                        </span>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Bookings Summary -->
    <div class="row g-3">
        <div class="col-md-3">
            <div class="card border-0 shadow rounded-4 p-3 text-center">
                <i class="bi bi-building text-primary mb-2" style="font-size: 2rem;"></i>
                <h4 class="fw-bold mb-0">@Model.HotelBookings.Count</h4>
                <small class="text-muted">Hotel Bookings</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow rounded-4 p-3 text-center">
                <i class="bi bi-shop text-success mb-2" style="font-size: 2rem;"></i>
                <h4 class="fw-bold mb-0">@Model.RestaurantBookings.Count</h4>
                <small class="text-muted">Restaurant Bookings</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow rounded-4 p-3 text-center">
                <i class="bi bi-car-front text-danger mb-2" style="font-size: 2rem;"></i>
                <h4 class="fw-bold mb-0">@Model.CarRentalBookings.Count</h4>
                <small class="text-muted">Car Rentals</small>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow rounded-4 p-3 text-center">
                <i class="bi bi-compass text-info mb-2" style="font-size: 2rem;"></i>
                <h4 class="fw-bold mb-0">@Model.TourBookings.Count</h4>
                <small class="text-muted">Tour Bookings</small>
            </div>
        </div>
    </div>

</div>

<style>
    body {
        background: #f0f4f8;
    }

    .profile-header {
        background: linear-gradient(135deg, #1e40af, #2563eb, #3b82f6);
        padding: 50px 30px;
        text-align: center;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        background: rgba(255,255,255,.2);
        border-radius: 20px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 36px;
        backdrop-filter: blur(10px);
    }

    .profile-role-badge {
        display: inline-block;
        background: rgba(255,255,255,.2);
        color: white;
        padding: 6px 18px;
        border-radius: 20px;
        font-size: .85rem;
        font-weight: 600;
        backdrop-filter: blur(10px);
    }

    .profile-stat {
        background: #f8fafc;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
    }

    .profile-stat i {
        font-size: 1.4rem;
        display: block;
        margin-bottom: 6px;
    }

    .stat-label {
        display: block;
        color: #6b7280;
        font-size: .78rem;
        margin-bottom: 4px;
    }

    .stat-value {
        display: block;
        font-weight: 700;
        color: #1e293b;
        font-size: .95rem;
        word-break: break-all;
    }
</style>
