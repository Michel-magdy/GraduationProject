@model GraduationProject.Models.HotelBooking

@{
    ViewData["Title"] = "Book Room";
}

<div class="container py-5">
    <div class="card shadow border-0 rounded-4 mx-auto" style="max-width: 500px;">
        <div class="card-body p-5">
            <h2 class="fw-bold mb-4">Book Room: @ViewBag.RoomNumber</h2>
            <p class="text-muted">Price per night: @(((decimal?)ViewBag.Price)?.ToString("C") ?? "N/A")</p>

            <form asp-action="BookRoom" method="post">
                <input type="hidden" asp-for="RoomId" />
                
                <div class="mb-3">
                    <label asp-for="CheckIn" class="form-label fw-bold"></label>
                    <input asp-for="CheckIn" class="form-control" type="date" />
                    <span asp-validation-for="CheckIn" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CheckOut" class="form-label fw-bold"></label>
                    <input asp-for="CheckOut" class="form-control" type="date" />
                    <span asp-validation-for="CheckOut" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 rounded-pill py-2">Confirm Booking</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
