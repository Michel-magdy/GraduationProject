@model IEnumerable<CarRental>

@{
    ViewData["Title"] = "Car Rentals";
}

<section class="management-page position-relative overflow-hidden">
    <div class="blur-circle bg-primary-gradient position-absolute top-0 start-0 translate-middle"></div>
    <div class="container position-relative z-index-2">
        <div class="management-hero d-flex flex-column flex-lg-row justify-content-between align-items-lg-end">
            <div>
                <span class="management-eyebrow">Mobility</span>
                <h1 class="management-title">Car Rentals</h1>
                <p class="management-subtitle">Track rental vehicles, daily prices, availability, and booking activity.
                </p>
            </div>
            <a asp-controller="CarRental" asp-action="Add"
               class="btn btn-primary rounded-custom px-4 py-2 fw-semibold shadow-sm">
                <i class="bi bi-plus-lg me-1"></i>Add Car
            </a>
        </div>

        <div class="management-card">
            @if (Model?.Any() == true)
            {
                <div class="table-responsive">
                    <table class="table management-table align-middle">
                        <thead>
                            <tr>
                                <th>Vehicle</th>
                                <th>Business</th>
                                <th>Price</th>
                                <th>Status</th>
                                <th>Bookings</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var car in Model)
                            {
                                <tr>
                                    <td data-label="Vehicle">
                                        <div class="entity-name">@car.Brand @car.Model</div>
                                        <div class="entity-muted">@car.Images</div>
                                    </td>
                                    <td data-label="Business">@(car.Business?.BusinessName ?? $"Business #{car.BusinessId}")
                                    </td>
                                    <td data-label="Price">@car.PricePerDay.ToString("C") / day</td>
                                    <td data-label="Status">
                                        <span class="status-pill @(car.Available ? "available" : "unavailable")">
                                            <i class="bi bi-circle-fill small"></i>@(car.Available ? "Available" :
                                                "Unavailable")
                                        </span>
                                    </td>
                                    <td data-label="Bookings">@car.CarRentalBookings.Count</td>
                                    <td data-label="Actions" class="text-lg-end">
                                        <div class="action-group">
                                            <a asp-controller="CarRental" asp-action="Details" asp-route-id="@car.Id"
                                               class="btn btn-outline-primary btn-sm rounded-custom">Details</a>
                                            <a asp-controller="CarRental" asp-action="Edit" asp-route-id="@car.Id"
                                               class="btn btn-primary btn-sm rounded-custom">Edit</a>
                                            <form asp-controller="CarRental" asp-action="Delete" asp-route-id="@car.Id"
                                                  method="post" class="d-inline">
                                                <button type="submit"
                                                        class="btn btn-outline-danger btn-sm rounded-custom">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-car-front-fill"></i>
                    <h2 class="h5 fw-bold mt-3 mb-2">No cars yet</h2>
                    <p class="text-muted mb-0">Rental vehicles will appear here once loaded.</p>
                </div>
            }
        </div>
    </div>
</section>
