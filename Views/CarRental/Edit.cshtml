@using GraduationProject.Models
@model CarRental

@{
    ViewData["Title"] = "Edit CarRental";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Edit CarRental</h2>
            <p class="text-muted">Update CarRental information and manage images.</p>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">
            <i class="bi bi-arrow-left"></i> Back
        </a>
    </div>

    <form asp-action="Edit" method="post">

        <input asp-for="Id" type="hidden" />
        <input asp-for="BusinessId" type="hidden" />

        <div class="row g-4">

            <div class="col-lg-8">

                <div class="card border-0 shadow rounded-4">

                    <div class="card-header bg-white border-0">
                        <h4 class="fw-bold mb-0">CarRental Information</h4>
                    </div>

                    <div class="card-body">

                        <div class="mb-3">
                            <label asp-for="Model" class="form-label"></label>
                            <input asp-for="Model" class="form-control rounded-3" />
                            <span asp-validation-for="Model" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Brand" class="form-label"></label>
                            <input asp-for="Brand" class="form-control rounded-3" />
                            <span asp-validation-for="Brand" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PricePerDay" class="form-label"></label>
                            <textarea asp-for="PricePerDay" rows="6" class="form-control rounded-3"></textarea>
                            <span asp-validation-for="PricePerDay" class="text-danger"></span>
                        </div>
                        <div class="mb-3 form-check form-switch">
                            <input asp-for="Available" class="form-check-input" />
                            <label asp-for="Available" class="form-check-label"></label>
                            <span asp-validation-for="Available" class="text-danger"></span>
                        </div>

                        

                    </div>

                </div>

            </div>

            <div class="col-lg-4">

                <div class="card border-0 shadow rounded-4">

                    <div class="card-header bg-white border-0">
                        <h5 class="fw-bold">CarRental Images</h5>
                    </div>

                    <div class="card-body">

                        <div id="imageContainer">
                            @if (Model.Images.Any())
                            {
                                @for (int i = 0; i < Model.Images.Count; i++)
                                {
                                    <div class="image-item mb-3 border rounded p-3">

                                        <input name="Images[@i].Id" type="hidden" value="@Model.Images[i].Id" />
                                        <input name="Images[@i].CarRentalId" type="hidden" value="@Model.Id" />

                                        <label class="form-label">Image URL</label>

                                        <input name="Images[@i].ImagePath" class="form-control mb-2"
                                               value="@Model.Images[i].ImagePath" />

                                        <img src="@Model.Images[i].ImagePath" class="img-fluid rounded-3"
                                             style="max-height:150px;" />

                                        <button type="button" class="btn btn-outline-danger btn-sm w-100 mt-2 remove-image">
                                            <i class="bi bi-trash"></i> Remove
                                        </button>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="alert alert-light border text-center no-images-msg">
                                    No images found.
                                </div>
                            }
                        </div>

                        <hr />

                        <label class="form-label fw-semibold">
                            Add Image URL
                        </label>

                        <div class="input-group">
                            <input type="text" id="newImageUrl" class="form-control" placeholder="https://..." />
                            <button type="button" id="addImageBtn" class="btn btn-primary">
                                Add
                            </button>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="mt-4 d-flex gap-2">

            <button type="submit" class="btn btn-primary px-4">
                <i class="bi bi-floppy"></i>
                Save Changes
            </button>

            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info">
                Details
            </a>

            <a asp-action="Index" class="btn btn-outline-secondary">
                Cancel
            </a>

        </div>

    </form>

</div>

<style>
    body {
        background: #f8fafc;
    }

    .card {
        border-radius: 22px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, .08) !important;
    }

    .form-control,
    .btn {
        border-radius: 14px;
    }

    .image-item img {
        width: 100%;
        height: 170px;
        object-fit: cover;
        box-shadow: 0 6px 18px rgba(0, 0, 0, .08);
    }
</style>

<script>
    function reindexImages() {
        var container = document.getElementById('imageContainer');
        var items = container.querySelectorAll('.image-item');
        items.forEach(function (item, index) {
            var inputs = item.querySelectorAll('input');
            inputs.forEach(function (input) {
                var name = input.getAttribute('name');
                if (name) {
                    input.setAttribute('name', name.replace(/Images\[\d+\]/, 'Images[' + index + ']'));
                }
            });
        });

        var noImagesMsg = container.querySelector('.no-images-msg');
        if (items.length === 0 && !noImagesMsg) {
            var msg = document.createElement('div');
            msg.className = 'alert alert-light border text-center no-images-msg';
            msg.textContent = 'No images found.';
            container.appendChild(msg);
        } else if (items.length > 0 && noImagesMsg) {
            noImagesMsg.remove();
        }
    }

    document.addEventListener("click", function (e) {
        if (e.target.classList.contains("remove-image") || e.target.closest(".remove-image")) {
            var imageItem = e.target.closest(".image-item");
            if (imageItem) {
                imageItem.remove();
                reindexImages();
            }
        }
    });

    document.getElementById('addImageBtn').addEventListener('click', function () {
        var urlInput = document.getElementById('newImageUrl');
        var url = urlInput.value.trim();
        if (!url) return;

        var container = document.getElementById('imageContainer');

        var noImagesMsg = container.querySelector('.no-images-msg');
        if (noImagesMsg) noImagesMsg.remove();

        var index = container.querySelectorAll('.image-item').length;

        var div = document.createElement('div');
        div.className = 'image-item mb-3 border rounded p-3';
        div.innerHTML =
            '<input name="Images[' + index + '].Id" type="hidden" value="0" />' +
            '<input name="Images[' + index + '].CarRentalId" type="hidden" value="@Model.Id" />' +
            '<label class="form-label">Image URL</label>' +
            '<input name="Images[' + index + '].ImagePath" class="form-control mb-2" value="' + url.replace(/"/g, '&quot;') + '" />' +
            '<img src="' + url.replace(/"/g, '&quot;') + '" class="img-fluid rounded-3" style="max-height:150px;" />' +
            '<button type="button" class="btn btn-outline-danger btn-sm w-100 mt-2 remove-image"><i class="bi bi-trash"></i> Remove</button>';

        container.appendChild(div);
        urlInput.value = '';
    });
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}